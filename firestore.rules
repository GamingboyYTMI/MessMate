rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. GLOBAL SAFETY NET
    match /{document=**} {
      allow read, write: if false;
    }

    // --- HELPER FUNCTIONS ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function getUser(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }

    function isAdmin() {
      // Bootstrapped Admin check + Database check
      return isSignedIn() && (
        request.auth.token.email == 'gamingboylive46@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         getUser(request.auth.uid).get('role', '') == 'Admin')
      );
    }

    function isMessOwner(messId) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             getUser(request.auth.uid).get('role', '') == 'MessOwner' && 
             getUser(request.auth.uid).get('messId', '') == messId;
    }

    // --- ENTITY VALIDATORS ---

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'role', 'status']) &&
             data.keys().size() >= 3 &&
             data.uid == request.auth.uid &&
             data.role in ['Admin', 'MessOwner', 'Student'] &&
             data.status in ['pending', 'approved', 'rejected'] &&
             (!('name' in data) || (data.name is string && data.name.size() <= 100)) &&
             (!('username' in data) || (data.username is string && data.username.size() <= 50)) &&
             (!('phone' in data) || (data.phone is string && data.phone.size() <= 20));
    }

    function isValidMess(data) {
      return data.keys().hasAll(['ownerId', 'name', 'status']) &&
             data.ownerId == request.auth.uid &&
             data.name is string && data.name.size() <= 100 &&
             data.status in ['pending', 'approved'] &&
             (!('address' in data) || (data.address is string && data.address.size() <= 500)) &&
             (!('upiId' in data) || (data.upiId is string && data.upiId.size() <= 100));
    }

    function isValidMenu(data, messId) {
      return data.messId == messId &&
             data.day is string &&
             (!('breakfast' in data) || (data.breakfast is string && data.breakfast.size() <= 500)) &&
             (!('lunch' in data) || (data.lunch is string && data.lunch.size() <= 500)) &&
             (!('dinner' in data) || (data.dinner is string && data.dinner.size() <= 500));
    }

    function isValidAttendance(data, messId) {
      return data.messId == messId &&
             data.studentId is string &&
             data.date is string &&
             data.mealType in ['breakfast', 'lunch', 'dinner'] &&
             data.status in ['present', 'absent'];
    }

    function isValidPayment(data, messId) {
      return data.messId == messId &&
             data.studentId is string &&
             data.amount is number &&
             data.month is string &&
             data.year is number &&
             data.status in ['paid', 'pending'];
    }

    // --- COLLECTION MATCHES ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && userId == request.auth.uid && isValidUser(incoming());
      allow update: if isSignedIn() && (
        isAdmin() || (
          userId == request.auth.uid && 
          isValidUser(incoming()) && 
          incoming().role == existing().role && 
          incoming().status == existing().status &&
          incoming().diff(existing()).affectedKeys().hasOnly(['name', 'username', 'phone', 'messId'])
        )
      );
    }

    match /messes/{messId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      
      allow create: if isSignedIn() &&
                    exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
                    getUser(request.auth.uid).get('role', '') == 'MessOwner' && 
                    isValidMess(incoming()) && 
                    incoming().get('status', 'pending') == 'pending';
      
      allow update: if isSignedIn() && (
        isAdmin() || 
        (isMessOwner(messId) && 
         isValidMess(incoming()) && 
         incoming().get('status', '') == existing().get('status', '') && 
         incoming().get('ownerId', '') == existing().get('ownerId', '') &&
         incoming().diff(existing()).affectedKeys().hasOnly(['name', 'address', 'upiId', 'upiQrUrl', 'ownerName']))
      );

      // Sub-collections
      match /menus/{menuId} {
        allow read: if isSignedIn();
        allow write: if isAdmin() || (isMessOwner(messId) && isValidMenu(incoming(), messId));
      }

      match /attendance/{attendanceId} {
        allow read: if isSignedIn() && (
          isMessOwner(messId) || 
          resource.data.get('studentId', '') == request.auth.uid || 
          isAdmin()
        );
        allow write: if isAdmin() || (isMessOwner(messId) && isValidAttendance(incoming(), messId));
      }

      match /payments/{paymentId} {
        allow read: if isSignedIn() && (
          isMessOwner(messId) || 
          resource.data.get('studentId', '') == request.auth.uid || 
          isAdmin()
        );
        allow create: if isAdmin() || (isMessOwner(messId) && isValidPayment(incoming(), messId));
        allow update: if isAdmin() || (
          isMessOwner(messId) && 
          incoming().get('studentId', '') == existing().get('studentId', '') &&
          incoming().diff(existing()).affectedKeys().hasOnly(['status', 'amount', 'receiptUrl'])
        );
      }
    }

    // Support for connection test
    match /test/connection {
      allow read: if isSignedIn();
    }
  }
}
